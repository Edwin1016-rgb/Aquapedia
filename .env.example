# .env.example - copiar a .env.local y completar con valores reales
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui
VITE_VAPID_PUBLIC_KEY=tu-vapid-public-key

# Variables para Cloudflare Pages Function (server-side, NO en .env.local):
# SUPABASE_URL (mismo valor que VITE_SUPABASE_URL)
# SUPABASE_SERVICE_ROLE_KEY (de Supabase Dashboard → Settings → API → service_role)
# VAPID_PUBLIC_KEY (mismo valor que VITE_VAPID_PUBLIC_KEY)
# VAPID_PRIVATE_KEY (de Supabase Dashboard → Settings → API → Push Notifications)
